# EditorConfig — consistent formatting across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.bat]
indent_style = space
indent_size = 4

[*.{rc,yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
